#!/bin/bash
#
# GOST Web 管理面板 - 快速启动脚本
# 用于已安装用户快速启动或重启Web管理面板
#

# 颜色定义
Green_font_prefix="\033[32m"
Red_font_prefix="\033[31m"
Yellow_font_prefix="\033[33m"
Font_color_suffix="\033[0m"
Info="${Green_font_prefix}[信息]${Font_color_suffix}"
Error="${Red_font_prefix}[错误]${Font_color_suffix}"
Warn="${Yellow_font_prefix}[警告]${Font_color_suffix}"

# 检查root权限
if [[ $EUID != 0 ]]; then
    echo -e "${Error} 此脚本需要root权限运行"
    exit 1
fi

echo -e "${Green_font_prefix}"
echo "╔════════════════════════════════════════╗"
echo "║   GOST Web 管理面板 服务控制          ║"
echo "╚════════════════════════════════════════╝"
echo -e "${Font_color_suffix}"

# 获取本机IP
local_ip=$(hostname -I | awk '{print $1}')
if [ -z "$local_ip" ]; then
    local_ip="127.0.0.1"
fi

case "$1" in
    start)
        echo -e "${Info} 启动GOST Web管理面板..."
        systemctl start gost-web-manager
        sleep 2
        if systemctl is-active --quiet gost-web-manager; then
            echo -e "${Green_font_prefix}✓ 服务已启动${Font_color_suffix}"
            echo -e "${Info} 访问地址: http://$local_ip:8888"
        else
            echo -e "${Error} 服务启动失败"
            systemctl status gost-web-manager
        fi
        ;;
    
    stop)
        echo -e "${Info} 停止GOST Web管理面板..."
        systemctl stop gost-web-manager
        sleep 1
        if ! systemctl is-active --quiet gost-web-manager; then
            echo -e "${Green_font_prefix}✓ 服务已停止${Font_color_suffix}"
        else
            echo -e "${Error} 服务停止失败"
        fi
        ;;
    
    restart)
        echo -e "${Info} 重启GOST Web管理面板..."
        systemctl restart gost-web-manager
        sleep 2
        if systemctl is-active --quiet gost-web-manager; then
            echo -e "${Green_font_prefix}✓ 服务已重启${Font_color_suffix}"
            echo -e "${Info} 访问地址: http://$local_ip:8888"
        else
            echo -e "${Error} 服务重启失败"
        fi
        ;;
    
    status)
        echo -e "${Info} GOST Web管理面板状态："
        if systemctl is-active --quiet gost-web-manager; then
            echo -e "${Green_font_prefix}● 运行中${Font_color_suffix}"
            echo -e "${Info} 访问地址: http://$local_ip:8888"
        else
            echo -e "${Red_font_prefix}● 已停止${Font_color_suffix}"
        fi
        systemctl status gost-web-manager
        ;;
    
    logs)
        echo -e "${Info} GOST Web管理面板日志（按 Q 退出）："
        journalctl -u gost-web-manager -f
        ;;
    
    *)
        echo -e "${Warn} 用法说明："
        echo ""
        echo "  $0 start     - 启动Web管理面板"
        echo "  $0 stop      - 停止Web管理面板"
        echo "  $0 restart   - 重启Web管理面板"
        echo "  $0 status    - 查看服务状态"
        echo "  $0 logs      - 查看实时日志"
        echo ""
        echo -e "${Info} 访问地址："
        echo "  http://$local_ip:8888"
        echo "  http://127.0.0.1:8888"
        ;;
esac
